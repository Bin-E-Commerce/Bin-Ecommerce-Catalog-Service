# ============================================================
# Catalog Service Environment
# ============================================================
# Scope:
# - Copy to services/catalog-service/.env for local standalone runs.
# - In production, inject only catalog-service variables through
#   Secret Manager, Kubernetes Secret, ECS Task Definition, or CI/CD secrets.
# ============================================================

NODE_ENV=development
PORT=3003
APP_VERSION=1.0.0
TYPEORM_LOGGING=false

# PostgreSQL - catalog database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=bin_ecommerce
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=bin_ecommerce_catalog
